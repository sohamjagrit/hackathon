# Sabre (hackathon-provided; token valid ~7 days from 2026-07-13, expires ~2026-07-20)
SABRE_MCP_URL=https://mcp.cert.sabre.com/mcp
SABRE_MCP_SKILLS_URL=https://mcp2.cert.sabre.com/mcp
SABRE_TOKEN=
SABRE_PCC=S5OM
SABRE_MODE=live

# Vocal Bridge — fill in after signup (vocalbridgeai.com -> API Keys tab, then vb agent create)
VOCAL_BRIDGE_API_KEY=
VB_AGENT_ID=

# Act 2 — disruption recovery (phone)
# HTTPS base URL of this FastAPI (Cloudflare Tunnel / paid ngrok).
# Free ngrok interstitial breaks VB HTTP tools.
PUBLIC_BASE_URL=
TRAVELER_PHONE=
HOTEL_PHONE=
VB_TRAVELER_AGENT_ID=
VB_HOTEL_AGENT_ID=
ACT2_RING_DELAY_S=2.5
ACT2_TRAVELER_CALL_TIMEOUT_S=600
ACT2_HOTEL_CALL_TIMEOUT_S=280
# Optional: path to vb binary if not on PATH
# VB_CLI_PATH=~/.local/bin/vb

# PayPal sandbox (developer.paypal.com -> sandbox app credentials)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BASE=https://api-m.sandbox.paypal.com

# Zapier MCP (itinerary email) — treat like a secret; never commit
# ZAPIER_MCP_URL=
